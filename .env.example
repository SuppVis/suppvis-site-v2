# Existing public content API used by blog/shop/research pages.
NEXT_PUBLIC_API_URL=

# AWS region for server-side DynamoDB writes.
AWS_REGION=us-east-1

# Server-only AWS credentials for a future least-privilege app IAM principal.
# Do not use a personal IAM user's access key in Vercel.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB tables. Use separate table names for production and preview.
DYNAMODB_BETA_APPLICATIONS_TABLE=
DYNAMODB_EMAIL_SUBSCRIBERS_TABLE=
DYNAMODB_SMS_SUBSCRIBERS_TABLE=
DYNAMODB_BROADCAST_AUDIT_LOGS_TABLE=

# SHA-256 hex hash of the bearer token accepted by /api/admin/broadcast-audit.
# Store the raw token only in your password manager, not in this repo.
ADMIN_BROADCAST_TOKEN_HASH=

# Welcome message templates exist, but real sends stay disabled until
# email unsubscribe and SMS STOP handling are implemented and verified.
WELCOME_EMAIL_ENABLED=false
WELCOME_SMS_ENABLED=false

# Recommended before production collection. Not wired yet in this code-only phase.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
